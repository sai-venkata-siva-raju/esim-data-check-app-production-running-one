# Rename this file to .env and fill in your access code.
RT_ACCESS_CODE=
# Optional: override the target API base URL.
API_BASE=https://api.esimaccess.com/api/v1/open
# Server port (optional).
PORT=3000
# This app uses POST /esim/query for ICCID status/usage and POST /balance/query for merchant balance.
# Optional: restrict CORS to one or more origins (comma-separated). Examples:
# CORS_ORIGIN=https://your-frontend.example.com
# CORS_ORIGIN=https://a.example.com,https://b.example.com
# Leave empty to allow all origins (development default)
CORS_ORIGIN=
